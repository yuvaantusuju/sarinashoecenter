{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "sarinashoecenter",
	"main": ".open-next/worker.js",
	"compatibility_date": "2025-01-01",
	"compatibility_flags": [
		"nodejs_compat"
	],
	// Cloudflare D1 database binding
	"d1_databases": [
		{
			"binding": "sarinashoe_db",
			"database_name": "sarinashoe-db",
			"database_id": "fcb92c05-aa67-40db-a325-431060f9e650",
			"remote": true
		}
	]
}